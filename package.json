{
  "name": "confluex",
  "version": "0.1.0",
  "private": true,
  "description": "Token-authenticated Confluence export CLI",
  "bin": {
    "confluex": "./bin/confluex.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:node": "node --test",
    "selftest": "node dist/main.js selftest",
    "lint:js": "standard confluex $(git ls-files '*.js' '*.mjs')",
    "lint:shell": "node scripts/lint-shell.js",
    "lint": "npm run lint:js && npm run lint:shell"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "standard": "^17.1.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "micromark-extension-gfm": "^3.0.0",
    "unist-util-visit": "^5.1.0"
  }
}
