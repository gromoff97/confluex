{
  "name": "confluex",
  "version": "0.1.0",
  "description": "Token-authenticated Confluence export CLI",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/gromoff97/confluex.git"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "bin": {
    "confluex": "./bin/confluex.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "npm run typecheck:src && npm run typecheck:tests",
    "typecheck:src": "tsc -p tsconfig.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.test.json --noEmit",
    "prepack": "npm run build",
    "test:node": "npm run build && node --test tests/node/*.test.ts",
    "lint:js": "node scripts/lint-js.js",
    "lint:ts": "eslint \"src/**/*.ts\" eslint.config.mjs --max-warnings 0",
    "lint:shell": "node scripts/lint-shell.js",
    "lint": "npm run lint:js && npm run lint:ts && npm run lint:shell"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/node": "^25.6.0",
    "eslint": "^8.57.1",
    "globals": "^17.6.0",
    "standard": "^17.1.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "micromark-extension-gfm": "^3.0.0",
    "unist-util-visit": "^5.1.0"
  }
}
