{
  "name": "confluex",
  "version": "0.1.0",
  "description": "Token-authenticated Confluence export CLI",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/gromoff97/confluex.git"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "bin": {
    "confluex": "./bin/confluex.js"
  },
  "files": [
    "bin/",
    "dist/",
    "lib/confluex-node/",
    "tests/fixtures/",
    "tests/live-bats/live-regression.bats",
    "tests/live-bats/helpers/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:node": "node --test",
    "selftest": "node dist/main.js selftest",
    "lint:js": "node scripts/lint-js.js",
    "lint:shell": "node scripts/lint-shell.js",
    "lint": "npm run lint:js && npm run lint:shell"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "standard": "^17.1.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "micromark-extension-gfm": "^3.0.0",
    "unist-util-visit": "^5.1.0"
  }
}
