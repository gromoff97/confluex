#!/usr/bin/env bash
if [[ -z "${BASH_VERSION:-}" ]]; then
  exec bash "$0" "$@"
fi
set -euo pipefail

SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_lib_dir() {
  local candidates=()
  if [[ -n "${CONFLUEX_LIB_DIR:-}" ]]; then
    candidates+=("$CONFLUEX_LIB_DIR")
  fi
  candidates+=(
    "$SCRIPT_DIR/lib/confluex"
    "$SCRIPT_DIR/../lib/confluex"
  )

  local candidate
  for candidate in "${candidates[@]}"; do
    if [[ -f "$candidate/main.sh" ]]; then
      cd "$candidate" >/dev/null 2>&1 && pwd
      return 0
    fi
  done

  printf 'ERROR: cannot locate confluex libraries. Tried: %s\n' "${candidates[*]}" >&2
  return 1
}

CONFLUEX_LIB_DIR="$(resolve_lib_dir)"
. "$CONFLUEX_LIB_DIR/main.sh"

confluex_main "$SCRIPT_PATH" "$CONFLUEX_LIB_DIR" "$@"
