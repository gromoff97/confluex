#!/usr/bin/env node
'use strict'

const { run } = require('./lib/confluex-node/main.js')

run(process.argv.slice(2), process)
  .then(exitCode => {
    process.exitCode = exitCode
  })
  .catch(error => {
    process.stderr.write(`ERROR: internal_error ${error.name}\n`)
    process.exitCode = 4
  })
